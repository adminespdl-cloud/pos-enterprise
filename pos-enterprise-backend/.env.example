APP_NAME="POS Enterprise"
APP_ENV=local
APP_KEY=base64:GENERATE_WITH_php_artisan_key_generate
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost:8000

APP_LOCALE=id
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=pos_enterprise
DB_USERNAME=pos_app_user
DB_PASSWORD=your_strong_password_here

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1

# Token TTL (dalam menit)
SANCTUM_TOKEN_TTL=1440
SANCTUM_CASHIER_TOKEN_TTL=720
SANCTUM_REFRESH_TOKEN_TTL=43200

# Rate Limiting
RATE_LIMIT_AUTH=10
RATE_LIMIT_API=300
RATE_LIMIT_SYNC=10

# Storage
FILESYSTEM_DISK=local
QRIS_IMAGE_PATH=public/qris

# Mail (opsional untuk notifikasi)
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS=noreply@pos-enterprise.com
MAIL_FROM_NAME="${APP_NAME}"
