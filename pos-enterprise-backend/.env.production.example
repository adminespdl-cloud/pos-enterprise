# ═══════════════════════════════════════════════════════════════════
# POS Enterprise — .env.production.example
# Salin ke .env.production lalu isi nilai yang sebenarnya
# JANGAN commit file .env.production ke repository!
# ═══════════════════════════════════════════════════════════════════

APP_NAME="POS Enterprise"
APP_ENV=production
APP_KEY=                          # Generate: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://api.YOUR_DOMAIN

LOG_CHANNEL=stderr
LOG_LEVEL=warning

# ── Database ──────────────────────────────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=postgres                  # Nama service Docker
DB_PORT=5432
DB_DATABASE=pos_enterprise
DB_USERNAME=pos_user
DB_PASSWORD=GANTI_PASSWORD_KUAT   # Min 20 karakter, acak

# ── Redis ─────────────────────────────────────────────────────────
REDIS_HOST=redis                  # Nama service Docker
REDIS_PORT=6379
REDIS_PASSWORD=GANTI_REDIS_PASSWORD

# ── Cache / Queue / Session via Redis ────────────────────────────
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=480              # 8 jam (menit)

# ── Sanctum ──────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=YOUR_DOMAIN,api.YOUR_DOMAIN

# ── CORS ─────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://YOUR_DOMAIN,https://api.YOUR_DOMAIN

# ── Security ─────────────────────────────────────────────────────
PIN_MAX_ATTEMPTS=3
PIN_LOCKOUT_MINUTES=15
API_RATE_LIMIT=60                 # Request per menit per user

# ── File Storage ─────────────────────────────────────────────────
FILESYSTEM_DISK=local
# Jika pakai S3/R2:
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-southeast-1
# AWS_BUCKET=pos-enterprise-assets

# ── Mail (opsional) ───────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@YOUR_DOMAIN
MAIL_FROM_NAME="POS Enterprise"
